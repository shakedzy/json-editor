# ---- Rust / Tauri ----
/src-tauri/target/
/src-tauri/gen/
/src-tauri/WixTools/
# Desktop icons under src-tauri/icons/ are committed so `tauri build` works
# on a fresh clone. Mobile icons are huge and unused — regenerated by
# `tauri icon` on demand if we ever ship mobile.
/src-tauri/icons/android/
/src-tauri/icons/ios/

